# نموذج ملف البيئة - انسخ هذا الملف واسمه .env.local للعمل المحلي
# Copy this file and rename it to .env.local for local development

# 📱 إعدادات التواصل | Communication Settings
NEXT_PUBLIC_WHATSAPP_PHONE=966580757487
NEXT_PUBLIC_WHATSAPP_MESSAGE_TEMPLATE="مرحباً، لدي استفسار حول"

# 🌐 إعدادات الموقع | Site Settings  
